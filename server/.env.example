# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
PGSSLMODE=require
JWT_SECRET=change_me_to_a_long_random_string


# ── App URLs ──────────────────────────────────────────────────────────────────
# APP_BASE_URL: your frontend URL (used for OAuth redirects and password reset emails)
APP_BASE_URL=http://localhost:3000
# POLAR_WEBHOOK_SERVER_URL: your deployed server URL (used to register Polar webhooks)
# Leave empty in local dev — webhook registration is skipped automatically
POLAR_WEBHOOK_SERVER_URL=https://your-server.onrender.com


# ── Polar API ─────────────────────────────────────────────────────────────────
# Get credentials at https://admin.polaraccesslink.com
POLAR_CLIENT_ID=your_polar_client_id
POLAR_CLIENT_SECRET=your_polar_client_secret
# Must match the callback URL registered in Polar admin
POLAR_REDIRECT_URI=https://your-server.onrender.com/api/v1/integrations/polar/callback


# ── Garmin API ────────────────────────────────────────────────────────────────
# Get credentials at https://developer.garmin.com
# Note: redirect_uri must be a deployed HTTPS URL — Garmin does not support localhost
GARMIN_CLIENT_ID=your_garmin_client_id
GARMIN_CLIENT_SECRET=your_garmin_client_secret
GARMIN_REDIRECT_URI=https://your-server.onrender.com/api/v1/integrations/garmin/callback


# ── Nodemailer ────────────────────────────────────────────────────────────────
# Used for password reset emails. MAIL_PASS should be an app password, not your account password.
# Gmail: https://support.google.com/accounts/answer/185833
MAIL_USER=your_email@example.com
MAIL_PASS=your_email_app_password


# ── OpenAI API ────────────────────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key
